int handler_write_{{ sid }}(SidHandlerContext *ctx, CoreconfValueT *value) {
    // Validate value type
{% if type == "boolean" %}
    if (value->type != CORECONF_TRUE && value->type != CORECONF_FALSE) {
        printf("Error: Expected boolean type for SID {{ sid }}\n");
        return -1;
    }
{% elif type in ["uint8", "uint16", "uint32", "uint64"] %}
    if (!isTypeUint(value->type)) {
        printf("Error: Expected unsigned integer type for SID {{ sid }}\n");
        return -1;
    }
{% elif type in ["int8", "int16", "int32", "int64"] %}
    if (!isTypeInt(value->type)) {
        printf("Error: Expected signed integer type for SID {{ sid }}\n");
        return -1;
    }
{% else %}
    if (value->type != {{ type_enum }}) {
        printf("Error: Expected type {{ type_enum }} for SID {{ sid }}\n");
        return -1;
    }
{% endif %}

    // Extract native value from CoreconfValueT
{% if type == "boolean" %}
    {{ c_type }} nativeValue = (value->type == CORECONF_TRUE);
{% elif type in ["uint8", "uint16", "uint32", "uint64"] %}
    {{ c_type }} nativeValue = getCoreconfValueAsUint64(value);
{% elif type in ["int8", "int16", "int32", "int64"] %}
    {{ c_type }} nativeValue = getCoreconfValueAsInt64(value);
{% else %}
    {{ c_type }} nativeValue = value->data.{{ data_field }};
{% endif %}

{% if keys %}
    // Extract keys from context
{% for key in keys %}
    {{ key.c_type }} {{ key.name }} = ({{ key.c_type }})ctx->keys->longList[{{ loop.index0 }}];
{% endfor %}

{% endif %}
    // Call user-implemented write function
{% if keys %}
    int result = {{ user_function }}({% for key in keys %}{{ key.name }}, {% endfor %}nativeValue);
{% else %}
    int result = {{ user_function }}(nativeValue);
{% endif %}

    // If user function succeeded, update the datastore
    if (result == 0) {
        uint64_t finalDeltaSID = 0;
        CoreconfValueT* parentContainer = navigateToParentContainer(
            ctx->coreconfModel, ctx->pathNode, {{ sid }}, &finalDeltaSID);

        if (parentContainer != NULL) {
            int insertResult = insertCoreconfHashMap(parentContainer->data.map_value, finalDeltaSID, value);
            if (insertResult != 0) {
                printf("Warning: Failed to update coreconfModel for SID {{ sid }}\n");
            }
        } else {
            printf("Error: Failed to navigate to parent for SID {{ sid }}\n");
            return -1;
        }
    }

    return result;
}
